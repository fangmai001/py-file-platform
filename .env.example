# PostgreSQL (used both by docker-compose db service and backend)
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform
POSTGRES_PORT=5432

# Backend connects to db via this URL.
# - Native dev (uvicorn on host, db in Docker): use localhost
# - Full docker-compose (backend also in Docker): use host "db"
DATABASE_URL=postgresql+psycopg2://platform:platform@localhost:5432/platform

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# Auth (generate a real secret with e.g. `openssl rand -hex 32`)
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional: bootstrap the first admin account on startup, since /api/admin/users
# requires an existing admin to call it. Only takes effect while no admin account
# exists yet; leave unset after the first admin is created.
# INITIAL_ADMIN_USERNAME=admin
# INITIAL_ADMIN_PASSWORD=change-me-to-a-real-password

# Frontend
VITE_API_BASE_URL=http://localhost:8000
