# PostgreSQL (used both by docker-compose db service and backend)
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform
POSTGRES_PORT=5432

# Backend connects to db via this URL.
# - Native dev (uvicorn on host, db in Docker): use localhost
# - Full docker-compose (backend also in Docker): use host "db"
DATABASE_URL=postgresql+psycopg2://platform:platform@localhost:5432/platform

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# Auth (generate a real secret with e.g. `openssl rand -hex 32`)
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional: bootstrap the first admin account on startup, since /api/admin/users
# requires an existing admin to call it. Only takes effect while no admin account
# exists yet; leave unset after the first admin is created.
# INITIAL_ADMIN_USERNAME=admin
# INITIAL_ADMIN_PASSWORD=change-me-to-a-real-password

# Optional: SMTP for outgoing mail (self-service password reset, upload
# notifications). If SMTP_HOST is left unset, emails are logged instead of sent,
# which is fine for local dev/testing.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=no-reply@example.com
# SMTP_FROM=notifications@example.internal
# SMTP_USE_TLS=true

# Base URL the frontend is served from, used to build links (e.g. password reset)
# that point back at the frontend from an email.
FRONTEND_BASE_URL=http://localhost:5173
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# LDAP auth (optional). These only seed the initial value of the DB-backed
# `ldap_settings` row the first time it's read; after that, LDAP config is managed
# by an admin via the "LDAP 設定" tab in /admin (see app/api/ldap_settings.py), not
# by these env vars. Leave LDAP_ENABLED unset/false for local-account-only
# deployments; the fields below only matter when it's true.
# LDAP_ENABLED=true
# LDAP_SERVER_URI=ldap://ldap.example.internal
# LDAP_BIND_DN=cn=service-account,dc=example,dc=internal
# LDAP_BIND_PASSWORD=change-me
# LDAP_BASE_DN=ou=people,dc=example,dc=internal
# LDAP_USER_SEARCH_FILTER=(uid={username})
# Frontend
VITE_API_BASE_URL=http://localhost:8000
